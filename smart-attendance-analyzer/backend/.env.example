# ==============================================================================
# Smart Attendance Pattern Analyzer — Backend Environment Variables
# ==============================================================================
# Copy this file to `.env` in the backend/ directory and fill in real values
# before deploying. Safe defaults are used for local development if these
# are left unset, but JWT_SECRET_KEY in particular must be changed for
# anything beyond your own machine.

# --- JWT Authentication ---
# Generate a strong random secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# --- Database ---
# SQLite is used by default (see database.py); no configuration needed
# unless you swap in a different SQLAlchemy-compatible database.
