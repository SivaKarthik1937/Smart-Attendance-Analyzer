# Base URL for the FastAPI backend.
# Leave blank (or unset) to use Vite's dev-server proxy (see vite.config.ts),
# which forwards /api requests to http://localhost:8000 during local dev.
# Set this explicitly when deploying the frontend separately from the backend,
# e.g. VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=